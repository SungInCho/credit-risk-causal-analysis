# ── Python ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
*.so

# ── Virtual environments ─────────────────────────────────
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# ── Jupyter ──────────────────────────────────────────────
.ipynb_checkpoints/
*/.ipynb_checkpoints/
profile_default/
ipython_config.py

# ── Raw data files (too large for git) ───────────────────
data/raw/*.csv
data/raw/*.zip
data/raw/*.gz
data/raw/*.parquet
# keep .gitkeep
!data/raw/.gitkeep

# ── Large intermediate outputs ────────────────────────────
outputs/intermediate/*.parquet
outputs/intermediate/*.csv
# keep meta.json
!outputs/intermediate/meta.json

# ── OS ───────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDEs ─────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ── Misc ─────────────────────────────────────────────────
*.log
*.tmp
*.bak
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/
